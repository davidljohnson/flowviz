{
  "name": "flowviz",
  "version": "1.0.0",
  "description": "AI-powered cybersecurity attack flow visualization tool using MITRE ATT&CK",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "tsc && vite build",
    "lint": "eslint . --report-unused-disable-directives",
