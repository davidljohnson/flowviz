    "start": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@mozilla/readability": "^0.6.0",
    "@mui/icons-material": "^5.15.10",
    "@mui/material": "^5.15.10",
    "@tanstack/react-query": "^5.20.5",
    "@types/dagre": "^0.7.53",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "dagre": "^0.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "file-type": "^22.0.1",
    "helmet": "^8.1.0",
    "html-to-image": "^1.11.13",
    "http-proxy-middleware": "^4.2.0",
    "ip-address": "^10.0.1",
    "jsdom": "^29.1.1",
    "node-fetch": "^3.3.2",
    "openai": "^6.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.10.3",
    "uuid": "^14.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
